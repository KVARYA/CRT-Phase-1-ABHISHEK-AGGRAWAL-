//PROBLEM 1---if condition
//to verify user's wether eligible for vote

#include<iostream>
using namespace std;

int main(){
    int age;
    cin>>age;
    
    if(age>=18){
        cout<<"Eligible for Vote"<<endl;
    }
    

    return 0;
}


//PROBLEM 2---if-esle condition
//to verify user's wether eligible for vote or note..?

#include<iostream>
using namespace std;

int main(){
    int age;
    cin>>age;
    
    if(age>=18){
        cout<<"Eligible for Vote"<<endl;
    } else {
        cout<<"Not Eligible for Vote"<<endl;
    }
    
    
    return 0;
}

//PROBLEM 3---Nested if-else condition
//to verify user's wether eligible for vote or note..?

#include<iostream>
using namespace std;

int main(){
    int age;
    cin>>age;
    
    if(age>=18){
        if(age>=100){
            cout<<"Eligible for Vote( But we are Super Senior Citizen)"<<endl;
        } else {
            cout<<"Eligible for Vote"<<endl;
        }
    } else {
         if(age<0){
                  cout<<"Enter a Valid Age"<<endl;
          } else{
             cout<<"Not Eligible for Vote"<<endl;
          }
    }
    
    return 0;
}
