// Home-Work
// Problem 9 -- Grade Calculator

#include<iostream>
using namespace std;

int main() {
    float marks;
    cout << "Enter the Marks: ";
    cin >> marks;

    // First check for invalid input
    if (marks < 0 || marks > 100) {
        cout << "Invalid Marks Entered";
    }
    else {
        if (marks >= 91) {
            cout << "A+ Grade";
        }
        else if (marks >= 75) {
            cout << "A Grade";
        }
        else if (marks >= 60) {
            cout << "B Grade";
        }
        else if (marks >= 45) {
            cout << "C Grade";
        }
        else if (marks >= 35) {
            cout << "D Grade";
        }
        else {
            cout << "Fail";
        }
    }

    return 0;
}


