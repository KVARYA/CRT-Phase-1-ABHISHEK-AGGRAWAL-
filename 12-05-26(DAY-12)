//Problemm 1--
// Recursion -- Print 1 to 10 numbers
#include <iostream>
using namespace std;

void printNumbers(int n) {
    // Base Condition
    if (n>10)
    return ;
    
    // Logic 
    cout<< n <<" ";
    printNumbers(n+1);
}
int main() {
    printNumbers(1);
    return 0;
}


//Problemm 2--
// Recursion -- Print Factorial of a number
#include <iostream>
using namespace std;

int factorial(int n) {
    // Base Condition
    if(n==0 || n==1){
        return 1;
    }
    
    // Logic 
    
    return n*factorial(n-1);
    
}
int main() {
    cout<<factorial(5);
    return 0;
}
