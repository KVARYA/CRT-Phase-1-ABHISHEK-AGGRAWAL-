// Homework
// Pronlem 13.1 --
// CountDown Timer (in seconds)

#include <iostream>
#include <unistd.h> // for sleep() on Linux/Unix
using namespace std;

int main() {
    int n;
    cout << "Enter countdown time (in seconds): ";
    cin >> n;

    for (int i = n; i >= 0; i--) {
        cout << i << endl;
        sleep(1); // wait for 1 second
    }

    cout << "Time's up!" << endl;
    return 0;
}


// Homework
// Pronlem 14 --
// Atm pin Retry System 

#include <iostream>
using namespace std;

int main() {
    int correctPIN = 1234;
    int enteredPIN;
    int attempts = 0;
    int maxAttempts = 3;

    while (attempts < maxAttempts) {
        cout << "Enter your PIN: ";
        cin >> enteredPIN;

        if (enteredPIN == correctPIN) {
            cout << "Access Granted!" << endl;
            return 0; // exit program
        } else {
            cout << "Incorrect PIN!" << endl;
            attempts++;
        }
    }

    cout << "Card Blocked. Too many incorrect attempts." << endl;
    return 0;
}

    

    


    

    
