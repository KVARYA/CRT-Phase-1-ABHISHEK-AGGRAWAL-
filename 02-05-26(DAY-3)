//Problem 9 -- 
//PRIME Number Check


#include <iostream>
using namespace std;
int main(){
   int n;
   cout<<"Enter a number:";
   cin>>n;
   bool isPrime = true;
   
   if( n<2){
       isPrime = false;
   }else {
       for(int i=2; i<n; i++){
           if (n%i == 0){
               isPrime = false;
               break;
           }
       }
   }
   if (isPrime){
       cout<<"Prime Number";
   } else{
       cout<<"Not a Prime Number";
   }
   
   
    
   return 0;
}

