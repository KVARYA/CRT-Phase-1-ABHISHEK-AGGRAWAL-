// Problem 1--
// Inheritance 
// Tpyes -- 1.1 Single Inheritance

#include <iostream>
using namespace std;
class vehicle{
    public:
    void start(){
        cout<<"Vehicle is start"<<endl;
    }
    
};

class car: public vehicle {
    public:
    void drive() {
        cout<<"Car is running"<<endl;
    }
    
    
};
int main(){
   car obj1;
   obj1.start();
   obj1.drive();
   
   return 0;
}

// Problem 2--
// Inheritance 
// Tpyes -- 1.2 Multilevel Inheritance

#include <iostream>
using namespace std;
class vehicle{
    public:
    void start(){
        cout<<"Vehicle is start..."<<endl;
    }
    
};

class car: public vehicle {
    public:
    void drive() {
        cout<<"Car is running...."<<endl;
    }
    
    
};
class speedoMeter : public car{
  public:
  void speed(){
      cout<<"Car speed is 120kmh..."<<endl;
  }
};
int main(){
   speedoMeter obj1;
   obj1.start();
   obj1.drive();
   obj1.speed();
   
   return 0;
}

// Problem 3--
// Inheritance 
// Tpyes -- 1.3 Hierarchical Inheritance

#include <iostream>
using namespace std;
class vehicle{
    public:
    void start(){
        cout<<"Vehicle is start..."<<endl;
    }
    
};

class car: public vehicle {
    public:
    void drive() {
        cout<<"Car is running...."<<endl;
    }
    
    
};
class bike : public vehicle{
  public:
  void drive2(){
      cout<<"Bike is running..."<<endl;
  }
};
int main(){
   bike obj1;
   obj1.start();
   obj1.drive2();
   
   car obj2;
   obj2.start();
   obj2.drive();
   return 0;
}

// Problem 4--
// Inheritance 
// Tpyes -- 1.4 Multiple Inheritance

#include <iostream>
using namespace std;
class Parent1{
    public:
    void giveMeMoney(){
        cout<<"Mummy paisa do mujhe"<<endl;
    }
};

class Parent2 {
    public:
    void giveMeMoney(){
        cout<<"Papa paisa do mujhe"<<endl;
    }
};

class Child : public Parent1, public Parent2 {
    
};
int main(){
   Child obj1;
   obj1.Parent1::giveMeMoney();
   obj1.Parent2::giveMeMoney();
   return 0;
}
