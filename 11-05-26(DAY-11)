// ROTATE ARRAY 189

class Solution {
public:
    void rotateArray(vector<int>& nums, int start, int end) {
        while (start < end) {
            swap(nums[start], nums[end]);
            start++;
            end--;
        }
    }
    void rotate(vector<int>& nums, int k) {
        int n = nums.size();
        k = k%n;
        rotateArray(nums, 0, n-1); // rotating complete Array
        rotateArray(nums, 0, k-1);// rotate k th element
        rotateArray(nums, k, n-1); // rotate k to n-1
        
        
    }
};
 // Reverse a STRING 344
class Solution {
public:
    void reverseString(vector<char>& s) {
        int n= s.size();
        int start=0; 
        int end = n-1;
        while(start < end){
            char c = s[start];
            s[start] = s[end];
            s[end]= c;

            start++;
            end--;
        }
    }
};

//Palindrome a String

#include <iostream>
using namespace std;
bool isPalindrome(string message) {
    int start =0;
    int end =message.size()-1;
    
    while (start < end) {
        if(message[start] != message[end] ){
            return false;
        }
        start++;
        end--;
    }
    return true;
}
int main(){
    string message;
    cout<<"Enter the String:";
    cin>> message;
    
    if(isPalindrome(message)) {
        cout<< "Palindrome";
    }
    else {
        cout<<"Not Palindrome...";
    }
    
    return 0;
}

