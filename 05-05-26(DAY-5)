//Problem 1--
//Pattern Printing Upper Right Angle triangle and its opposite


#include <iostream>
using namespace std;

int main(){
    int n;
    cin>>n;
    
    for(int i=1; i<=n; i++){
        for(int j=1; j<=i; j++){
            cout<<"*";
        } cout<<"\n";
       
    }  
    
    // Print lower triangle 
    
    for(int k=n-1; k>=1; k--){
            for(int l=1; l<=k; l++){
                cout<<"*";
            } cout<<"\n";
         
     }
     
    
    return 0;
}

