//Problem -- 1
// Function Overriding

#include <iostream>
using namespace std;

class Applience {
    public:
    virtual void turnOn(){
    cout<<"Applience is starting up..."<<endl;
    }
    virtual void work() = 0; // pure virtual function
};

class Fan : public Applience{
    public:
    void turnOn() override {
        cout<<"Fan blades are moving slowley..."<<endl;
    }
    void work() override {
        cout<<"Fan is giving me cool air..."<<endl;
    }
    
};

class Toaster : public Applience{
    public:
    void work() override {
        cout<<"Toaster is heating up the breads..."<<endl;
    }
};
int main(){
    Applience* kitchenApp;
    Fan myfan;
    kitchenApp = &myfan;
    kitchenApp->turnOn();
    kitchenApp->work();
    
    Toaster myToast;
    kitchenApp = &myToast;
    kitchenApp-> turnOn();
    kitchenApp-> work();
    return 0;
}


//Problem -- 2
//Constructor Overloading

#include <iostream>
using namespace std;

class Rectnagle{
  public:
  int length;
  int width;
  
  Rectnagle(){
      length = 1;
      width = 1;
  }
  Rectnagle(int side) {
      length = side;
      width = side;
  }
  Rectnagle(int side1, int side2){
      length = side1;
      width = side2;
  }
  
  void showArea(){
      cout<< length * width << "\n";
  }
};

int main(){
    Rectnagle r1;
    Rectnagle r2(5);
    Rectnagle r3(5,4);
    
    r1.showArea();
    r2.showArea();
    r3.showArea();

    return 0;
}

