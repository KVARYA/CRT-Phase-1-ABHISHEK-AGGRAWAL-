// Problem 1 --
//Print 1 to 10 Number of times


#include <iostream>
using namespace std;
int main(){
    
    for(int i=1; i<=10; i++){
        
        //What to print in the pattern
        for(int j=1; j<=10; j++){
            cout<<j << " " ;
        }
        cout<< "\n";
    }
    
     
    return 0;
    
}

